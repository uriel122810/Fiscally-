# ─── SAT e.firma Configuration ──────────────────────────────────────────
# Rutas a los archivos de tu e.firma (FIEL) vigente.
# NUNCA subas estos archivos a un repositorio git.
SAT_CER_PATH=./efirma/certificado.cer
SAT_KEY_PATH=./efirma/llave.key
SAT_KEY_PASSWORD=tu-contraseña-de-efirma

# RFC de la empresa (debe coincidir con la e.firma)
SAT_RFC=GTE210401AB3

# ─── Server Configuration ───────────────────────────────────────────────
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─── Database ────────────────────────────────────────────────────────────
DB_PATH=./data/fiscally.db
